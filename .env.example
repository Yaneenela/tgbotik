# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# 3x-UI Panel
XUI_URL=http://your-server:2053
XUI_USERNAME=admin
XUI_PASSWORD=your_password
XUI_INBOUND_ID=1

# Subscription URL (публичный адрес подписки)
# Формат: http://SERVER_IP:PORT/sub/ или https://domain/sub/
# {uuid} будет заменён на UUID клиента
SUB_URL_TEMPLATE=http://your-server:2053/sub/{uuid}

# CryptoBot (Crypto Pay API) — опционально
CRYPTO_BOT_TOKEN=

# USDT TRC20 — ручная оплата (опционально)
USDT_ADDRESS=
USDT_NETWORK=TRC20

# Планы подписки (JSON)
# traffic_gb = 0 означает безлимит
PLANS='[
  {"name":"1 месяц","price":10,"days":30,"traffic_gb":100},
  {"name":"3 месяца","price":25,"days":90,"traffic_gb":300},
  {"name":"6 месяцев","price":45,"days":180,"traffic_gb":0}
]'

# Цена в USDT/CryptoBot
CURRENCY=USD
