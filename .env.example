# Telegram
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username_without_at
ADMIN_IDS=123456789,987654321

# 3x-UI Panel
XUI_URL=http://your-server:2053
XUI_USERNAME=admin
XUI_PASSWORD=your_password
XUI_INBOUND_ID=1

# Subscription URL (публичный адрес подписки)
# Формат: http://SERVER_IP:PORT/sub/ или https://domain/sub/
# {uuid} будет заменён на UUID клиента
SUB_URL_TEMPLATE=http://your-server:2053/sub/{uuid}

# ЮKassa (приём платежей картами и ЮMoney)
# ShopId и Секретный ключ из личного кабинета YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Планы подписки (JSON)
# traffic_gb = 0 означает безлимит
# Цена в рублях
PLANS='[
  {"name":"1 месяц","price":199,"days":30,"traffic_gb":100},
  {"name":"3 месяца","price":499,"days":90,"traffic_gb":300},
  {"name":"6 месяцев","price":899,"days":180,"traffic_gb":0}
]'

CURRENCY=RUB
